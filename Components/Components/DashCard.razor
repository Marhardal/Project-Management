@using ProjectManager.Components.Account.Shared

<div class="card mb-sm-2">
    <div class="row g-2">
        <div class="text-center col-md-3 col-sm-4 col-lg-3 border-end justify-content-center align-items-center align-content-center" style="height: 80px; line-height: 80px;">
            <i class="@Icon me-3"></i>
        </div>
        <div class="mx-auto col-md-8 col-sm-7 col-lg-8 text-center">
            <div class="card-body">
                <h6 class="">@Title</h6>
                <p class="card-text">@Info</p>
            </div>
        </div>
    </div>
</div>


@code {
    [Parameter]
    public required string Title { get; set; }
    [Parameter]
    public required string Info { get; set; }
    [Parameter]
    public required string Icon { get; set; }
}

