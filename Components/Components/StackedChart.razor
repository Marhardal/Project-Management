<canvas id="monthChart"></canvas>

<script>
    const monthCtx = document.getElementById('monthChart');

    new Chart(monthCtx, {
        type: 'bar',
        data: {
            labels: ['Jan','Feb','Mar','Apr'],
            datasets: [
            {
                label: 'Approved',
                data: [3,5,4,6],
                backgroundColor: '#198754'
            },
            {
                label: 'Returned',
                data: [1,2,1,3],
                backgroundColor: '#dc3545'
            },
            {
                label: 'Under Review',
                data: [2,1,3,2],
                backgroundColor: '#ffc107'
            }]
        },
        options: {
            responsive: true,
            scales: {
                x: { stacked: true },
                y: { stacked: true }
            }
        }
    });
</script>