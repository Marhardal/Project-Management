@page "/Project/Status"

<div class="my-4 row">
    <div class="col-md-4">
        <h3>Project by Status</h3>
    </div>
    <div class="col-md-4">
        <div class="mb-3 input-group">
            <span class="input-group-text" id="basic-addon1">From</span>
            <input type="month" class="form-control" placeholder="Search" aria-label="Username" aria-describedby="basic-addon1">
        </div>
    </div>
    <div class="col-md-4">
        <div class="mb-3 input-group">
            <span class="input-group-text" id="basic-addon1">To</span>
            <input type="month" class="form-control" placeholder="Search" aria-label="Username" aria-describedby="basic-addon1">
        </div>
    </div>
    </div>

<div class="border rounded bg-body-tertiary">
    <table class="table p-2 mt-2 rounded-pill table-hover">
    <thead class="text-white bg-dark">
        <tr class="">
            <th scope="col">#</th>
            <th scope="col">Status</th>
            <th scope="col">Duration</th>
            <th scope="col">Project Count</th>
            <th scope="col"></th>
        </tr>
    </thead>
    <tbody>
        <tr>
            <th scope="row">1</th>
            <td class="py-2">Completed</td>
                <td class="py-2">@DateTime.Now.AddYears(-1).ToString("MM-yyyy") - @DateTime.Now.ToString("MM-yyyy")</td>
            <td class="py-2">20</td>
                <td>
                    <div class="p-1 text-center">
                        <NavLink class="p-2 rounded border-warning border bg-outline-warning text-warning" href="/Tracking">
                            <i class="bi bi-eye-fill"></i>
                        </NavLink>
                    </div>
                </td>
        </tr>
            <tr>
                <th scope="row">2</th>
                <td class="py-2">In-Progress</td>
                <td class="py-2">@DateTime.Now.AddYears(-1).ToString("MM-yyyy") - @DateTime.Now.ToString("MM-yyyy")</td>
                <td class="py-2">20</td>
                <td>
                    <div class="p-1 text-center">
                            <NavLink class="p-2 rounded border-warning border bg-outline-warning text-warning" href="/Tracking">
                                <i class="bi bi-eye-fill"></i>
                            </NavLink>
                    </div>
                </td>
            </tr>
            <tr>
                <th scope="row">3</th>
                <td class="py-2">Pending</td>
                <td class="py-2">@DateTime.Now.AddYears(-1).ToString("MM-yyyy") - @DateTime.Now.ToString("MM-yyyy")</td>
                <td class="py-2">20</td>
                <td>
                    <div class="p-1 text-center">
                        <NavLink class="p-2 rounded border-warning border bg-outline-warning text-warning" href="/Tracking">
                            <i class="bi bi-eye-fill"></i>
                        </NavLink>
                    </div>
                </td>
            </tr>
    </tbody>
</table>
</div>
