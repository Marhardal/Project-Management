                <div class="mb-3">
                    <label for="exampleFormControlInput1" class="form-label">Proponet Location</label>
                    <input type="text" class="form-control" id="exampleFormControlInput1"  placeholder="Enter Proponent Location." required>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                <button type="button" class="btn btn-primary">Create</button>
            </div>
        </div>
    </div>
